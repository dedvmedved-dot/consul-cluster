node_name = "{{ inventory_hostname }}"
server = false
data_dir = "/var/lib/consul"
bind_addr = "{{ ansible_host }}"
client_addr = "0.0.0.0"

retry_join = ["192.168.122.91", "192.168.122.92", "192.168.122.93"]

ports {
  dns = 8600
  http = 8500
}

dns_config {
  allow_stale = true
  max_stale = "15s"
}
